# Production environment — copy to .env.prod and fill in all values
# Usage: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d

# ── Elastic Stack ─────────────────────────────────────────────────────────────
ELASTIC_VERSION=8.13.0

# Built-in superuser password (set during first boot)
ELASTIC_PASSWORD=CHANGE_ME_strong_password_here

# Per-service credentials (create with commands in DEPLOYMENT.md)
KIBANA_SYSTEM_PASSWORD=CHANGE_ME_kibana_system_pw
FILEBEAT_WRITER_PASSWORD=CHANGE_ME_filebeat_writer_pw
DETECTION_READER_PASSWORD=CHANGE_ME_detection_reader_pw
RESPONSE_WRITER_PASSWORD=CHANGE_ME_response_writer_pw
KIBANA_SETUP_PASSWORD=CHANGE_ME_kibana_setup_pw

# Kibana saved-objects encryption key (must be >= 32 random characters)
KIBANA_ENCRYPTION_KEY=CHANGE_ME_32_chars_minimum_random_key_here

# ── Ports ─────────────────────────────────────────────────────────────────────
ES_PORT=9200
KIBANA_PORT=5601

# ── Detection tuning ──────────────────────────────────────────────────────────
DETECTION_POLL_INTERVAL=30
BRUTE_FORCE_THRESHOLD=5
BRUTE_FORCE_WINDOW=60

# ── Response ──────────────────────────────────────────────────────────────────
# enforce = real iptables rules  |  simulate = log only (safe default)
RESPONSE_MODE=enforce
BLOCK_DURATION=3600

# ── GHCR images ───────────────────────────────────────────────────────────────
# Update IMAGE_PREFIX to match your GitHub username if you forked the project
IMAGE_PREFIX=ghcr.io/gerijacki/mini-soc
TAG=latest
