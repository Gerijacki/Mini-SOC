ELASTIC_VERSION=8.13.0
ES_HOST=http://elasticsearch:9200
ES_PORT=9200
KIBANA_PORT=5601

INDEX_LOGS=soc-logs
INDEX_ALERTS=soc-alerts
INDEX_BLOCKED=soc-blocked-ips

LOG_DIR=/logs
LOGS_PER_SECOND=2
ATTACK_RATIO=0.3
BRUTE_FORCE_BURST=8

DETECTION_POLL_INTERVAL=15
BRUTE_FORCE_THRESHOLD=5
BRUTE_FORCE_WINDOW=60

# simulate (safe, default) | enforce (real iptables - requires NET_ADMIN cap)
RESPONSE_MODE=simulate
BLOCK_DURATION=3600
